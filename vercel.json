{
  "functions": {
    "api/auth/login.js": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/auth/me.js": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/contests/index.js": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/contests/[id].js": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/contests/[id]/participants.js": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/participants/[id].js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/|assets/|.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
