# =====================================================
# DATABASE (Neon PostgreSQL)
# =====================================================
# Get this from https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# =====================================================
# AUTH
# =====================================================
# Secret key untuk sign JWT token. Generate random string minimal 32 char.
# Bisa pake: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-random-secret-min-32-chars

# =====================================================
# ADMIN SEED
# =====================================================
# Credentials untuk admin default (dibuat saat db:seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# =====================================================
# FRONTEND
# =====================================================
# Base URL frontend (untuk CORS). Boleh pake "*" untuk development.
FRONTEND_ORIGIN=http://localhost:5173
